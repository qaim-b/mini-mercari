{
  "version": 2,
  "trailingSlash": false,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/$",
      "dest": "/web_client/index.html"
    },
    {
      "src": "^/web_client$",
      "dest": "/web_client/index.html"
    },
    {
      "src": "^/web_client/(.*)$",
      "dest": "/web_client/$1"
    },
    {
      "src": "^/(.*)$",
      "dest": "/web_client/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ]
}
